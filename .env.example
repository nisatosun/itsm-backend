# Database Configuration
POSTGRES_DB=itsm_db
POSTGRES_USER=itsm_user
POSTGRES_PASSWORD=itsm_password
POSTGRES_PORT=5432

# Application Server
BACKEND_PORT=8080
SERVER_PORT=8080

# Keycloak Authentication
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/itsm-realm
KEYCLOAK_JWK_SET_URI=http://localhost:8081/realms/itsm-realm/protocol/openid-connect/certs
KEYCLOAK_REALM=itsm-realm

# File Upload
UPLOAD_DIR=./uploads
